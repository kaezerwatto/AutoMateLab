# =====================================================================
#  AutoMateLab INF3421 — Variables d'environnement
# ---------------------------------------------------------------------
#  Copiez ce fichier en `.env.local` puis renseignez vos clés Supabase.
#  Sans ces variables, l'application fonctionne en mode local
#  (persistance via localStorage du navigateur).
# =====================================================================

# URL du projet Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co

# Clé publique « anon » (Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-cle-anon

# Schéma exposé (doit être ajouté dans Settings → API → Exposed schemas)
NEXT_PUBLIC_SUPABASE_SCHEMA=automatelab
